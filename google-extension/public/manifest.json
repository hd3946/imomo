{
  "manifest_version": 3,
  "name": "Chat Extension",
  "version": "1.0",
  "description": "A chat extension built with React",
  "permissions": ["activeTab", "storage", "tabs"],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "logo192.png",
      "48": "logo192.png",
      "128": "logo192.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
